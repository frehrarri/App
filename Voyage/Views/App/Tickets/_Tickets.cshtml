@model TicketsVM

@* controller renders setupticketsettings if settings have not been set up *@

@{
    Model.Sections.Add(new SectionDTO { Title = "Completed", SectionOrder = 991, SectionId = -1 });
    Model.Sections.Add(new SectionDTO { Title = "Discontinued", SectionOrder = 992, SectionId = -2 });

    DateTime sprintEnd = DateTime.MinValue;
    switch (Model.Settings.RepeatSprintOption)
    {
        case (int)Constants.RepeatSprint.Weekly:
            sprintEnd = Model.Settings.SprintStart!.Value.AddDays(7);
            break;
        case (int)Constants.RepeatSprint.BiWeekly:
            sprintEnd = Model.Settings.SprintStart!.Value.AddDays(14);
            break;
        case (int)Constants.RepeatSprint.Monthly:
            sprintEnd = Model.Settings.SprintStart!.Value.AddMonths(1);
            break;
        default:
            break;
    }
}

<div id="tickets-container">

    <div id="card-header-container">

        @if (Model.Settings.RepeatSprintOption != (int)Constants.RepeatSprint.Never)
        {
            <div id="sprint-header" class="card-header">
                <h4>Sprint @Model.Sprint.SprintId: </h4>
                <h4>@Model.Sprint?.StartDate!.Value.ToString("dd MMM yyyy") - @sprintEnd.ToString("dd MMM yyyy")</h4>
            </div>

        @*     <div class="card-header">
                @foreach (var s in Model.Sections)
                {
                        <label>@s.Title:</label>
                        <span>@Model.Tickets.Count(x => x.SectionId == s.SectionId)</span>
                        <br />
                }
                
            </div> *@
        }

    </div>
    
    <div id="filter-container">
        <label for="section-filter">Filter Sections:</label>
        <select id="section-filter">
            <option value="0">All</option>
            @foreach (var s in Model.Sections.OrderBy(s => s.SectionOrder))
            {
                <option value="@s.SectionId">@s.Title</option>
            }
        </select>
    </div>

    @foreach (var s in Model.Sections.OrderBy(s => s.SectionOrder))
    {

        var sectionTickets = Model.Tickets.Where(t => t.SectionTitle == s.Title).OrderByDescending(t => t.PriorityLevel);

        int ticketCount = sectionTickets.Count();
        int numOfPages = (int)Math.Ceiling(ticketCount / 5.0);

        var tickets = sectionTickets.Take(5).ToList();

        <form>
            @Html.AntiForgeryToken()
            <div id="@(s.Title)-container" class="section-container" data-sectionid="@s.SectionId" tabindex="0">
                <div class="content-container" style="margin-top:0px;">
                    <h5 id="heading-@(s.Title)" class="heading">@s.Title</h5>

                    <table class="app-table">
                        <thead>
                            <tr class="app-table-row">
                                <th class="app-table-header"></th>
                                <th class="app-table-header" style="width:75px;">ID</th>
                                <th class="app-table-header">@nameof(TicketVM.Title)</th>
                                <th class="app-table-header">@nameof(TicketVM.Status)</th>
                                <th class="app-table-header">@AddSpacesToSentence(nameof(TicketVM.AssignedTo))</th>
                                <th class="app-table-header">@AddSpacesToSentence(nameof(TicketVM.DueDate))</th>
                                <th class="app-table-header">@AddSpacesToSentence(nameof(TicketVM.PriorityLevel))</th>
                                <th class="app-table-header">Last Edit</th>
                                <th class="app-table-header">Editor</th>
                                <th class="app-table-header">Created</th>
                                <th class="app-table-header">Author</th>
        @* 
                                @if (s.Title != "Discontinued" && s.Title != "Completed")
                                {
                                    <th class="app-table-header">
                                        <button class="btnAddTicket primary-btn" data-section="@s.Title">Add</button>
                                    </th>
                                } *@

                            </tr>
                        </thead>
                        <tbody>
                            @if (tickets.Any())
                            {
                                foreach (TicketVM ticket in tickets)
                                {

                                    <tr class="app-table-row">
                                        <td class="app-table-data">
                                            <input type="checkbox" />
                                        </td>
                                        <td class="app-table-data">
                                            <a href="#" class="goto-ticket" data-id="@ticket.TicketId">@ticket.TicketId</a>
                                        </td>
                                        <td class="app-table-data">
                                            <a href="#" class="goto-ticket" data-id="@ticket.TicketId">@ticket.Title</a>
                                        </td>
                                        <td class="app-table-data">@AddSpacesToSentence(ticket.Status)</td>
                                        <td class="app-table-data">@ticket.AssignedTo</td>
                                        <td class="app-table-data">@FormatUtcDate(ticket.DueDate, false)</td>
                                        <td class="app-table-data">@ticket.PriorityLevel</td>
                                        <td class="app-table-data">@FormatUtcDate(ticket.ModifiedDate, false)</td>
                                        <td class="app-table-data">@ticket.ModifiedBy</td>
                                        <td class="app-table-data">@FormatUtcDate(ticket.CreatedDate, false)</td>
                                        <td class="app-table-data">@ticket.CreatedBy</td>
                                    </tr>

                                }
                            }
                            else
                            {
                                <tr class="app-table-row">
                                    <td class="no-results app-table-data" colspan="11">
                                        <span>No Results</span>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table> 
                </div>
       
                <div class="pagination-container">
                    <div class="dv-btns-container">
                        @if (s.Title != "Discontinued" && s.Title != "Completed")
                        {
                            <button class="add-btn primary-btn" type="button">Add Ticket</button>
                            <button class="completed-btn secondary-btn disabled" type="button" disabled>Mark Completed</button>
                            <button class="discontinue-btn warning-btn disabled" type="button" disabled>Discontinue</button>
                         @*    <button id="remove-btn" class="warning-btn @(tickets.Any() ? "" : "hidden") type="button">Delete</button> *@
                        }
                    </div>

                    <div class="pagination-buttons">

                        <div class="record-count-selector">
                            <span>Results per page: </span>
                            <select id="sel-take-section-@(s.Title)" class="paginate select-list" data-section="@s.Title">
                                <option value="5" selected>5</option>
                                <option value="10">10</option>
                                <option value="15">15</option>
                                <option value="20">20</option>
                            </select>
                        </div>

                        <button id="btn-left-section-@(s.Title)" class="paginate paginate-arrow left" data-section="@s.Title" type="button" disabled>
                            <i class="fa-solid fa-arrow-left"></i>
                        </button>

                        <span class="page-btn-container">

                            @if (sectionTickets.Count() > 0)
                            {
                                for (int i = 1; i <= numOfPages; i++)
                                {
                                    @if (i == 1)
                                    {
                                        <span class="ellipsis-low hidden">...</span>
                                        <button id="btn-page@(i)-section-@(s.Title)" class="paginate page selected" data-page="@i" data-section="@s.Title" disabled>@i</button>
                                    }
                                    //prevent more than 7 shown page icons at a time
                                    else if (i == 6)
                                    {
                                        break;
                                    }
                                    else
                                    {
                                        <button id="btn-page@(i)-section-@(s.Title)" class="paginate page" data-page="@i" data-section="@s.Title">@i</button>
                                    }
                                }
                                //indicate there are more pages
                                if (numOfPages > 6)
                                {
                                    <span class="ellipsis-high">...</span>
                                }
                            }
                            else
                            {
                                <button id="btn-page1-section-@(s.Title)" class="paginate page selected" data-page="1" data-section="@s.Title" disabled>1</button>
                            }

                        </span>

                        @if (numOfPages < 2 || sectionTickets.Count() == 0)
                        {
                            <button id="btn-right-section-@(s.Title)" class="paginate paginate-arrow right" data-section="@s.Title" type="button" disabled>
                                <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        }
                        else
                        {
                            <button id="btn-right-section-@(s.Title)" class="paginate paginate-arrow right" data-section="@s.Title" type="button">
                                <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        }

                        @* manual page input *@
                        <div class="page-details">
                            <input type="number" class="paginate page-input" value="1" />
                            <span> of @((sectionTickets.Count() / 5) + 1) Pages</span>
                        </div>
                    </div>

                    @if (ticketCount == 0)
                    {
                        <span class="record-count"><span class="record-low">0</span> to <span class="record-high">0</span> of <span class="record-total">0</span> Records</span>
                    }
                    else if (ticketCount <= 4)
                    {
                        <span class="record-count"><span class="record-low">1</span> to <span class="record-high">@ticketCount</span> of <span class="record-total">@ticketCount</span> Records</span>
                    }
                    else
                    {
                        <span class="record-count"><span class="record-low">1</span> to <span class="record-high">5</span> of <span class="record-total">@ticketCount</span> Records</span>
                    }
                    
                </div>
                <input class="hdn-total-tickets" type="hidden" value="@ticketCount" />
            </div>
        </form>
        
    }

</div>

<input type="hidden" id="hdnTotalTicketCount" value="@Model.Tickets.Count()" />
<input type="hidden" id="hdnSprint" data-sprintId="@Model.Sprint?.SprintId" data-sprintStart="@Model.Sprint?.StartDate" data-sprintEnd="@Model.Sprint?.EndDate" />

